NODE_ENV=production
PORT=3010

# URL interna usada pelo servidor Next para chamar a API Nest.
API_BASE_URL_INTERNAL=http://127.0.0.1:4000

# Use true se o site estiver em HTTPS. Em HTTP interno/LAN, use false.
WEB_SESSION_COOKIE_SECURE=false

# Opcional. Hoje o navegador usa rotas do próprio Next para autenticação.
# NEXT_PUBLIC_API_BASE_URL=http://192.168.58.159

# Caminho opcional para o pacote exportado do legado, usado pelas telas de reconciliacao.
# NOVA_LEGACY_IMPORT_PATH=/opt/nova/legacy-import.json
