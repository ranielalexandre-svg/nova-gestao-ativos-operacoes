NODE_ENV=production
PORT=4000

# PostgreSQL usado pela API Nest/Prisma.
DATABASE_URL=postgresql://nova_user:troque-esta-senha@127.0.0.1:5432/nova_gestao?schema=public

# Gere valores longos e diferentes para producao:
# openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-com-32-ou-mais-caracteres
INTEGRATION_SECRET_KEY=troque-por-outro-segredo-com-32-ou-mais-caracteres

# Origens permitidas se o navegador falar direto com a API.
# Se a API ficar apenas interna atrás do Next/Nginx, pode deixar vazio.
CORS_ORIGINS=http://192.168.58.159

# Endpoints externos permitidos para integrações. Se vazio, a API aceita os
# hosts cadastrados, mas ainda aplica timeout nas chamadas.
# INTEGRATION_ALLOWED_HOSTS=zabbix.exemplo.local,monitoramento.exemplo.local
INTEGRATION_REQUEST_TIMEOUT_MS=10000

# Usado apenas para o seed inicial do administrador.
ADMIN_EMAIL=admin@nova.local
ADMIN_PASSWORD=troque-esta-senha

# Caminho opcional para o pacote exportado do legado.
# NOVA_LEGACY_IMPORT_PATH=/opt/nova/legacy-import.json

# Pasta local para anexos enviados pela aplicacao.
# NOVA_UPLOAD_DIR=/opt/nova/uploads
