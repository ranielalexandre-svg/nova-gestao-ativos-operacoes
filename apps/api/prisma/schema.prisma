generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  role               String
  passwordHash       String
  isActive           Boolean            @default(true)
  assignedExceptions ExceptionCase[]    @relation("ExceptionAssignee")
  activities         ActivityEntry[]    @relation("ActivityActor")
  exceptionComments  ExceptionComment[] @relation("ExceptionCommentAuthor")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}


model Partner {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  isActive       Boolean        @default(true)
  units          Unit[]
  occurrences    Occurrence[]
  maintenances   Maintenance[]
  exceptionCases ExceptionCase[]
  activities     ActivityEntry[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Unit {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  city           String?
  state          String?
  isActive       Boolean        @default(true)
  partnerId      String
  partner        Partner        @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  equipments     Equipment[]
  occurrences    Occurrence[]
  maintenances   Maintenance[]
  exceptionCases ExceptionCase[]
  activities     ActivityEntry[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([partnerId])
}

model Equipment {
  id             String         @id @default(cuid())
  tag            String         @unique
  name           String
  type           String
  serialNumber   String?
  status         String         @default("active")
  isActive       Boolean        @default(true)
  unitId         String
  unit           Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)
  occurrences    Occurrence[]
  maintenances   Maintenance[]
  exceptionCases ExceptionCase[]
  activities     ActivityEntry[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([unitId])
}

model Integration {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  type           String
  baseUrl        String
  apiPath        String?
  authMode       String         @default("none")
  apiTokenEnc    String?
  usernameEnc    String?
  passwordEnc    String?
  isActive       Boolean        @default(true)
  exceptionCases ExceptionCase[]
  activities     ActivityEntry[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Occurrence {
  id             String         @id @default(cuid())
  code           String         @unique
  title          String
  description    String?
  severity       String         @default("medium")
  status         String         @default("open")
  source         String?
  partnerId      String?
  unitId         String?
  equipmentId    String?
  partner        Partner?       @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  unit           Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  equipment      Equipment?     @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  maintenances   Maintenance[]
  exceptionCases ExceptionCase[]
  activities     ActivityEntry[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([partnerId])
  @@index([unitId])
  @@index([equipmentId])
  @@index([severity])
  @@index([status])
}

model Maintenance {
  id             String         @id @default(cuid())
  code           String         @unique
  title          String
  description    String?
  type           String         @default("preventive")
  status         String         @default("planned")
  scheduledAt    DateTime?
  completedAt    DateTime?
  partnerId      String?
  unitId         String?
  equipmentId    String?
  occurrenceId   String?
  partner        Partner?       @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  unit           Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  equipment      Equipment?     @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  occurrence     Occurrence?    @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)
  exceptionCases ExceptionCase[]
  activities     ActivityEntry[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([partnerId])
  @@index([unitId])
  @@index([equipmentId])
  @@index([occurrenceId])
  @@index([type])
  @@index([status])
}

model DocumentAttachment {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  name        String
  storedName  String
  mimeType    String?
  size        Int      @default(0)
  storagePath String
  source      String   @default("upload")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([createdAt])
}

model ExceptionCase {
  id                  String             @id @default(cuid())
  code                String             @unique
  title               String
  description         String?
  kind                String             @default("generic")
  severity            String             @default("medium")
  status              String             @default("open")
  source              String             @default("manual")
  fingerprint         String?            @unique
  queueKey            String             @default("ops-general")
  classification      String             @default("generic")
  impact              String             @default("medium")
  urgency             String             @default("medium")
  priorityScore       Int                @default(50)
  triageStatus        String             @default("pending")
  silencedUntil       DateTime?
  acknowledgedAt      DateTime?
  resolvedAt          DateTime?
  firstResponseDueAt  DateTime?
  resolveDueAt        DateTime?
  breachedAt          DateTime?
  lastActivityAt      DateTime?
  assigneeUserId      String?
  automationId        String?
  slaPolicyId         String?
  partnerId           String?
  unitId              String?
  equipmentId         String?
  integrationId       String?
  occurrenceId        String?
  maintenanceId       String?
  assignee            User?              @relation("ExceptionAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  automation          AutomationRule?    @relation(fields: [automationId], references: [id], onDelete: SetNull)
  slaPolicy           SlaPolicy?         @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)
  partner             Partner?           @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  unit                Unit?              @relation(fields: [unitId], references: [id], onDelete: SetNull)
  equipment           Equipment?         @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  integration         Integration?       @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  occurrence          Occurrence?        @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)
  maintenance         Maintenance?       @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)
  activities          ActivityEntry[]
  comments            ExceptionComment[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([severity])
  @@index([source])
  @@index([queueKey])
  @@index([triageStatus])
  @@index([priorityScore])
  @@index([assigneeUserId])
  @@index([automationId])
  @@index([slaPolicyId])
  @@index([partnerId])
  @@index([unitId])
  @@index([equipmentId])
  @@index([integrationId])
  @@index([occurrenceId])
  @@index([maintenanceId])
  @@index([firstResponseDueAt])
  @@index([resolveDueAt])
  @@index([breachedAt])
}


model SlaPolicy {
  id                   String          @id @default(cuid())
  code                 String          @unique
  name                 String
  kind                 String          @default("generic")
  severity             String          @default("medium")
  queueKey             String          @default("ops-general")
  firstResponseMinutes Int             @default(30)
  resolveMinutes       Int             @default(240)
  isActive             Boolean         @default(true)
  exceptionCases       ExceptionCase[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([kind])
  @@index([severity])
  @@index([queueKey])
  @@index([isActive])
}

model ExceptionComment {
  id          String        @id @default(cuid())
  exceptionId String
  userId      String
  body        String
  isInternal  Boolean       @default(true)
  exceptionCase ExceptionCase @relation(fields: [exceptionId], references: [id], onDelete: Cascade)
  author      User          @relation("ExceptionCommentAuthor", fields: [userId], references: [id], onDelete: Restrict)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([exceptionId, createdAt])
  @@index([userId])
}

model AutomationRule {
  id                String          @id @default(cuid())
  code              String          @unique
  name              String
  detector          String
  severity          String          @default("high")
  cadence           String          @default("every_5_minutes")
  thresholdMinutes  Int?
  enabled           Boolean         @default(true)
  createExceptions  Boolean         @default(true)
  createActivities  Boolean         @default(true)
  resolveOnRecovery Boolean         @default(true)
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  exceptionCases    ExceptionCase[]
  runs              AutomationRun[]
  activities        ActivityEntry[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([enabled])
  @@index([detector])
  @@index([cadence])
  @@index([nextRunAt])
}

model AutomationRun {
  id           String         @id @default(cuid())
  ruleId       String
  status       String         @default("success")
  startedAt    DateTime       @default(now())
  finishedAt   DateTime?
  hitsCount    Int            @default(0)
  createdCount Int            @default(0)
  updatedCount Int            @default(0)
  summary      String?
  errorMessage String?
  rule         AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  activities   ActivityEntry[]

  @@index([ruleId])
  @@index([status])
  @@index([startedAt])
}

model ActivityEntry {
  id            String          @id @default(cuid())
  kind          String          @default("note")
  source        String          @default("manual")
  title         String
  description   String?
  severity      String?
  userId        String?
  exceptionId   String?
  automationId  String?
  automationRunId String?
  partnerId     String?
  unitId        String?
  equipmentId   String?
  integrationId String?
  occurrenceId  String?
  maintenanceId String?
  actor         User?           @relation("ActivityActor", fields: [userId], references: [id], onDelete: SetNull)
  exceptionCase ExceptionCase?  @relation(fields: [exceptionId], references: [id], onDelete: SetNull)
  automation    AutomationRule? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  automationRun AutomationRun?  @relation(fields: [automationRunId], references: [id], onDelete: SetNull)
  partner       Partner?        @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  unit          Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  equipment     Equipment?      @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  integration   Integration?    @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  occurrence    Occurrence?     @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)
  maintenance   Maintenance?    @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([kind])
  @@index([source])
  @@index([severity])
  @@index([userId])
  @@index([exceptionId])
  @@index([automationId])
  @@index([automationRunId])
  @@index([partnerId])
  @@index([unitId])
  @@index([equipmentId])
  @@index([integrationId])
  @@index([occurrenceId])
  @@index([maintenanceId])
}
